rules_version = '2';

// ============================================================================
// Firestore Security Rules — Virar Stationery & Jumbo Xerox
//
// Threat model: the website is fully public and anonymous (no customer login).
// So the rules must let anonymous visitors SUBMIT data without ever being able
// to READ other people's data, enumerate collections, or tamper with records.
//
// Paste these in: Firebase Console > Firestore Database > Rules > Publish.
// ============================================================================
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- leads ----------------------------------------------------------
    // Contact + bulk enquiries captured before the WhatsApp redirect.
    // Clients may CREATE only (validated). They can NEVER read, list, update,
    // or delete — so the customer database is write-only from the web and
    // cannot leak. The shop reads/manages leads in the Firebase console.
    match /leads/{leadId} {
      allow create: if isValidLead();
      allow read, update, delete: if false;
    }

    // ---- orders ---------------------------------------------------------
    // Live order tracking. A customer can read ONE order by its (unguessable)
    // id for real-time status — but cannot LIST/enumerate orders, and cannot
    // write. The shop creates/updates orders in the console (or a future
    // authenticated admin tool).
    match /orders/{orderId} {
      allow get: if true;
      allow list, write: if false;
    }

    // ---- pickups --------------------------------------------------------
    // Public-safe "social proof" entries shown on the homepage. Read-only for
    // clients; the shop curates them in the console.
    match /pickups/{pickupId} {
      allow read: if true;
      allow write: if false;
    }

    // Everything else is denied by default.
    match /{document=**} {
      allow read, write: if false;
    }

    // --- validation -------------------------------------------------------
    // Bounds the shape/size of submitted leads to limit abuse and junk.
    function isValidLead() {
      let d = request.resource.data;
      return d.size() <= 20
        && d.name is string && d.name.size() > 0 && d.name.size() <= 120
        && d.source is string
        && d.createdAt == request.time
        && (!('phone' in d)       || (d.phone is string       && d.phone.size() <= 25))
        && (!('email' in d)       || (d.email is string       && d.email.size() <= 160))
        && (!('message' in d)     || (d.message is string     && d.message.size() <= 2000))
        && (!('description' in d) || (d.description is string  && d.description.size() <= 2000));
    }
  }
}
